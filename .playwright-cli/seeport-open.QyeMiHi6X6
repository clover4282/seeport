<!doctype html><html><body><script>window._opened=[];window.open=function(url,target){window._opened.push({url,target});};function openPort(port){window.open("http://localhost:"+port,"_blank");}</script><div id="root"></div><script>const p={port:3000,process:{pid:1,name:"dev",user:"me"},isFavorite:false};let html="";html += `<div class="port-row" onclick="openPort(${p.port})"\n    <div class="port-num">${p.port}</div>\n    <div class="actions"><button class="fav-btn" onclick="event.stopPropagation()">fav</button></div>\n  </div>`;document.getElementById("root").innerHTML=html;</script></body></html>
