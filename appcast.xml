            <title>Version 1.2</title>
            <sparkle:version>1.2</sparkle:version>
            <sparkle:shortVersionString>1.2</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <ul>
                    <li>Energy optimization: reduced shell process spawning</li>
                    <li>Cache Docker availability check (30s interval)</li>
                    <li>Cache working directory lookups per PID</li>
                    <li>Parallelize port scan and Docker container fetch</li>
                    <li>Default refresh interval changed to 10s</li>
                    <li>Refresh interval options: 5s/10s/20s/30s</li>
                </ul>
            ]]></description>
